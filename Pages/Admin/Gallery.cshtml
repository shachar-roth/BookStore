@page
@model BookBoutique.Pages.Admin.GalleryModel
@{
    ViewData["Title"] = "ניהול עולם עין המלך";
}

<section class="admin-shell">
    <div class="admin-toolbar">
        <div>
            <h1>עולם עין המלך</h1>
        </div>
        <div class="admin-actions">
            <a class="btn btn-secondary-outline" asp-page="/Admin/Index">חזרה לאדמין</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <section class="confirmation-banner" aria-live="polite">
            <strong>@Model.StatusMessage</strong>
        </section>
    }

    <section class="admin-grid">
        <section class="simple-page admin-editor">
            <h2>@(Model.Editor.Id == Guid.Empty ? "פריט חדש" : "עריכת פריט")</h2>

            <form method="post" asp-page-handler="Save" class="admin-form" enctype="multipart/form-data">
                <input asp-for="Editor.Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <label>
                    כותרת
                    <input asp-for="Editor.Title" class="form-control" />
                    <span asp-validation-for="Editor.Title" class="text-danger"></span>
                </label>

                <label>
                    פרטים שיופיעו מתחת לתמונה
                    <textarea asp-for="Editor.Details" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="Editor.Details" class="text-danger"></span>
                </label>

                <label>
                    קובץ תמונה (לא חובה)
                    <input asp-for="Editor.ImageFile" class="form-control" type="file" accept=".jpg,.jpeg,.png,.webp,.gif,image/*" />
                    <span asp-validation-for="Editor.ImageFile" class="text-danger"></span>
                </label>

                @if (!string.IsNullOrWhiteSpace(Model.Editor.ExistingFileName))
                {
                    <p class="admin-file-hint">הקובץ הנוכחי: @Model.Editor.ExistingFileName</p>
                }

                <label class="checkbox-row">
                    <input asp-for="Editor.IsPublished" />
                    לפרסם את הפריט באתר
                </label>

                <div class="admin-actions">
                    <button type="submit" class="btn btn-accent">שמירה</button>
                    <a class="btn btn-secondary-outline" asp-page="/Admin/Gallery">פריט חדש</a>
                </div>
            </form>
        </section>

        <section class="simple-page admin-list">
            <h2>פריטים קיימים במערכת</h2>

            @foreach (var item in Model.Items)
            {
                <article class="admin-item admin-gallery-item">
                    <div class="admin-gallery-summary">
                        @if (!string.IsNullOrWhiteSpace(item.FileName))
                        {
                            <img src="@item.PublicUrl" alt="@item.Title" class="admin-gallery-thumb" />
                        }
                        else
                        {
                            <div class="admin-gallery-thumb admin-gallery-thumb-placeholder">ללא תמונה</div>
                        }
                        <div>
                            <h3>@item.Title</h3>
                            @if (!string.IsNullOrWhiteSpace(item.Details))
                            {
                                <p>@item.Details</p>
                            }
                            <p>@item.OriginalFileName</p>
                            <div class="admin-meta">
                                <span>@(item.IsPublished ? "מפורסם" : "טיוטה")</span>
                                <span>@item.UpdatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        </div>
                    </div>
                    <div class="admin-item-actions">
                        <form method="post" asp-page-handler="Edit">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-secondary-outline">עריכה</button>
                        </form>
                        <form method="post" asp-page-handler="Delete" onsubmit="return confirm('למחוק את הפריט הזה?');">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-danger-soft">מחיקה</button>
                        </form>
                    </div>
                </article>
            }
        </section>
    </section>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
