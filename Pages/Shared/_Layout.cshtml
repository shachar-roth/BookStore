<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - עין המלך</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+Hebrew:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BookBoutique.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <div class="container site-header">
            <img class="series-icon" src="~/media/branding/series-icon.png" alt="" aria-hidden="true" />
            <a class="navbar-brand" asp-area="" asp-page="/Index">עין המלך</a>
            <img class="series-icon" src="~/media/branding/series-icon.png" alt="" aria-hidden="true" />
        </div>
    </header>
    <div class="container site-shell">
        <main role="main" class="site-main pb-3">
            @RenderBody()
        </main>
        <footer class="footer">
            <span>&copy; 2026 עין המלך</span>
            <a asp-area="" asp-page="/Privacy">פרטיות</a>
        </footer>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
